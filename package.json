{
  "name": "mojipass",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/types/core/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt/module.js",
      "types": "./dist/types/nuxt/module.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "bin": {
    "mojipass-create": "./dist/create.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently -n API,UI -c cyan,magenta \"tsx server/dev.ts\" \"vite\"",
    "dev:ui": "vite",
    "dev:api": "tsx server/dev.ts",
    "build": "vue-tsc -b && vite build",
    "build:css": "tailwindcss -i src/tokens.css -o dist/style.css --minify",
    "build:lib": "vite build --config vite.lib.config.ts && npm run build:css",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "setup": "tsx scripts/setup.ts",
    "prepare": "npm run build:lib"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@vueuse/core": "^13.0.0",
    "@vueuse/motion": "^3.0.0",
    "bcryptjs": "^3.0.2",
    "cookie-signature": "^1.2.2",
    "hono": "^4.7.0",
    "js-yaml": "^4.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-signature": "^1.1.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.0"
  }
}
